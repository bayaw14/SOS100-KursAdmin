<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – EduAdmin</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@{
    var token = Context.Session.GetString("JwtToken");
    var role  = Context.Session.GetString("UserRole") ?? "";
    var name  = Context.Session.GetString("UserName") ?? "";
}

@if (!string.IsNullOrEmpty(token))
{
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="white" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c0 1.66 4 3 6 3s6-1.34 6-3v-5"/>
                </svg>
            </div>
            <span class="sidebar-brand">EduAdmin</span>
        </div>

        <ul class="sidebar-nav">
            <li>
                <a asp-controller="Home" asp-action="Index"
                   class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Dashboard
                </a>
            </li>

            @* ── ÄNDRAT: Student-meny tillagd ── *@
            @if (role == "Student")
            {
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
                        </svg>
                        Kursutbud
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
                        </svg>
                        Mina kurser
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Schema
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                        </svg>
                        Kommunikation
                    </a>
                </li>
            }

            @* ── ÄNDRAT: Lärar-meny tillagd ── *@
            @if (role == "Teacher")
            {
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 19.5A2.5 2.5 0 016.5 17H20"/>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/>
                        </svg>
                        Mina kurser
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        Schema
                    </a>
                </li>
                <li>
                    <a href="#" class="nav-item">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                        </svg>
                        Kommunikation
                    </a>
                </li>
            }

            @* ── OFÖRÄNDRAT: Admin-meny ── *@
            @if (role == "Admin")
            {
                <li class="nav-label">Admin</li>
                <li>
                    <a asp-controller="Inloggning" asp-action="Users"
                       class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inloggning" && ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                        <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                        </svg>
                        Hantera användare
                    </a>
                </li>
            }

            @* ── ÄNDRAT: Ändra lösenord tillagd för alla roller ── *@
            <li>
                <a asp-controller="Inloggning" asp-action="ChangePassword"
                   class="nav-item @(ViewContext.RouteData.Values["action"]?.ToString() == "ChangePassword" ? "active" : "")">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2"/>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                    </svg>
                    Ändra lösenord
                </a>
            </li>
        </ul>

        @* ── OFÖRÄNDRAT: Sidebar footer ── *@
        <div class="sidebar-footer">
            <div class="user-pill">
                <div class="user-avatar">@(name.Length > 0 ? name[0].ToString().ToUpper() : "U")</div>
                <div class="user-meta">
                    <span class="user-email">@name</span>
                    <span class="user-role">
                        @(role == "Admin" ? "Administratör" : role == "Teacher" ? "Lärare" : "Student")
                    </span>
                </div>
            </div>
            <a asp-controller="Inloggning" asp-action="Logout" class="logout-btn" title="Logga ut">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </a>
        </div>
    </nav>

    <div class="main-content">
        <header class="topbar">
            <button class="menu-toggle" onclick="toggleSidebar()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <h1 class="page-title">@ViewData["Title"]</h1>
        </header>
        <div class="content-area">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<!-- Cookie Banner -->
<div id="cookie-banner" class="cookie-banner">
    <div class="cookie-content">
        <div class="cookie-text">
            <strong>Denna webbplats använder cookies</strong>
            <p>EduAdmin använder cookies för att säkerställa att du får den bästa upplevelsen.
               Nödvändiga cookies krävs för att systemet ska fungera, inklusive inloggning och session.</p>
        </div>
        <div class="cookie-actions">
            <button onclick="acceptCookies()" class="cookie-btn-accept">Tillåt alla</button>
            <button onclick="acceptNecessary()" class="cookie-btn-necessary">Endast nödvändiga</button>
            <button onclick="denyCookies()" class="cookie-btn-deny">Avvisa</button>
        </div>
        <div class="cookie-toggles">
            <div class="cookie-toggle-item">
                <span>Nödvändig</span>
                <div class="toggle-on">PÅ</div>
            </div>
            <div class="cookie-toggle-item">
                <span>Inställningar</span>
                <label class="toggle">
                    <input type="checkbox" id="settings-cookie" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
            <div class="cookie-toggle-item">
                <span>Statistik</span>
                <label class="toggle">
                    <input type="checkbox" id="stats-cookie" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>
    </div>
</div>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>