@model SOS100_KursAdmin_MVC.Models.InloggningViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logga in – EduAdmin</title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

<div class="login-page">
    <div class="login-card">

        <div class="login-left">
            <div class="login-icon-box">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
                     stroke="white" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c0 1.66 4 3 6 3s6-1.34 6-3v-5"/>
                </svg>
            </div>
            <h1>Välkommen till EduAdmin</h1>
            <p>Din centrala portal för kurser, schema och akademisk kommunikation.</p>
        </div>

        <div class="login-right">
            <h2>Logga in</h2>
            <p class="login-sub">Ange dina uppgifter för att fortsätta</p>

            <div class="tabs">
                <button type="button" class="tab-btn active" id="tab-student"
                        onclick="switchTab('student')">Student</button>
                <button type="button" class="tab-btn" id="tab-teacher"
                        onclick="switchTab('teacher')">Lärare / Admin</button>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-alert">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <span>@error.ErrorMessage</span>
                    }
                </div>
            }

            <form asp-controller="Inloggning" asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label asp-for="Email">E-postadress</label>
                    <div class="input-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                            <polyline points="22,6 12,13 2,6"/>
                        </svg>
                        <input asp-for="Email" type="email"
                               placeholder="du@universitet.se"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Lösenord</label>
                    <div class="input-wrap">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input asp-for="Password" type="password"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <button type="submit" class="login-btn" id="login-btn">
                    <span id="btn-label">Logga in</span>
                    <div class="btn-spinner" id="btn-spinner"></div>
                    <svg id="btn-arrow" viewBox="0 0 24 24" fill="none"
                         stroke="white" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </button>
            </form>
        </div>

    </div>
</div>

<script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>